# Copy to .env, fill in, then:  source .env
# .env is gitignored — never commit real keys.

# --- Google Cloud ---------------------------------------------------------
export PROJECT_ID=YOUR_PROJECT_ID
export REGION=us-central1
export CLUSTER=anthropic-agent-sandbox

# --- Anthropic ------------------------------------------------------------
# Environment key (sk-ant-oat01-...) — worker + dispatcher auth to the work
# queue. The ONLY credential that ever reaches a sandbox pod.
export ANTHROPIC_ENVIRONMENT_KEY=sk-ant-oat01-PLACEHOLDER

# Org API key — stats-adapter reads work.stats.depth. Never reaches a sandbox.
export ANTHROPIC_API_KEY=sk-ant-api03-PLACEHOLDER

# Environment ID (env_...) — which Managed Agents environment to serve.
export ANTHROPIC_ENVIRONMENT_ID=env_PLACEHOLDER

# Agent ID (agent_...) — created once via `ant beta:agents create` (README
# "Run a session" step 1). Used by scripts/fire_session.py, not by the cluster.
export ANTHROPIC_AGENT_ID=agent_PLACEHOLDER

# --- Deploy knobs ---------------------------------------------------------
export OVERLAY=01_single_session
export TAG=dev
# GCS bucket for /mnt/session/outputs (created by terraform/storage.tf).
export SESSION_BUCKET=${PROJECT_ID}-claude-session-outputs

# --- Terraform wiring (no edits needed) -----------------------------------
export TF_VAR_project_id=${PROJECT_ID}
export TF_VAR_region=${REGION}
export TF_VAR_cluster_name=${CLUSTER}
export TF_VAR_anthropic_environment_key=${ANTHROPIC_ENVIRONMENT_KEY}
export TF_VAR_anthropic_api_key=${ANTHROPIC_API_KEY}
